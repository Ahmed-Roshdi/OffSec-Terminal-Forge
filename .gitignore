# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment / secrets (never commit real keys) ──────────
.env
.env.local
.env.*.local

# ── OS ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editors ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Generated pipeline output ───────────────────────────────
# Ignored locally so `git status` stays clean during development —
# regenerating output/maps, output/scripts, output/dialogues is one
# command away (`python engines/orchestrator.py` + alien_generator).
#
# The CI workflow (Workflow-Output.yml) intentionally BYPASSES this
# with `git add -f output/maps output/scripts output/dialogues`, so
# generated assets ARE committed and pushed to main on every run.
# This is the standard "ignore locally, track remotely" pattern —
# do not remove this block, it is not a bug.
output/